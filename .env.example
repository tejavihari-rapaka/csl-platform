# Database - PostgreSQL connection string
# For docker-compose.dev.yml: postgresql://csl:csl_dev_password@localhost:5432/csl
DATABASE_URL="postgresql://csl:csl_dev_password@localhost:5432/csl"

# Redis - for caching, sessions, rate limiting
# For docker-compose: redis://localhost:6379
REDIS_URL="redis://localhost:6379"

# MinIO - S3-compatible object storage for images/uploads
# For docker-compose: http://localhost:9000
MINIO_ENDPOINT="http://localhost:9000"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"

# NextAuth.js - required when adding authentication
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here"
# Local dev: http://localhost:3000
NEXTAUTH_URL="http://localhost:3000"
